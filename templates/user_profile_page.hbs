<main role="main">
  <div class="container">
    <div style="background: var(--bg-card); border: 0.5px solid var(--card-border); border-radius: var(--radius); padding: 32px; box-shadow: var(--card-shadow);">
      <h1>{{user.name}}</h1>
      {{#if user.photo}}
        <img src="{{user.photo.content_url}}" alt="{{user.name}}" style="width: 80px; height: 80px; border-radius: 50%; margin-bottom: 16px;">
      {{/if}}
      <p class="text-muted text-small">Member since {{date user.created_at}}</p>
    </div>
  </div>
</main>