<main role="main">
  <div class="container">
    <nav aria-label="Breadcrumb">{{breadcrumbs}}</nav>

    <div class="search-results">
      <h1 class="search-results-heading">
        {{#if query}}
          Results for "{{query}}"
        {{else}}
          Search
        {{/if}}
      </h1>

      <div class="search-container" role="search" style="margin-bottom: 32px; max-width: 100%;">
        {{search submit=false}}
      </div>

      {{#if results}}
        <ul class="search-results-list">
          {{#each results}}
            <li class="search-result">
              <h2 class="search-result-title">
                <a href="{{url}}">{{title}}</a>
              </h2>
              <p class="search-result-description">{{text}}</p>
              <p class="search-result-meta">
                {{#each path_steps}}
                  <a href="{{url}}">{{name}}</a>
                {{/each}}
              </p>
            </li>
          {{/each}}
        </ul>

        {{pagination}}
      {{else}}
        <div style="text-align: center; padding: 48px 0;">
          <p style="font-size: 1.125rem; color: var(--text-secondary);">No results found for "{{query}}"</p>
          <p class="text-muted text-small">Try different keywords or browse our categories below.</p>
          {{#link 'help_center' class='btn-secondary'}}Browse all articles{{/link}}
        </div>
      {{/if}}
    </div>
  </div>
</main>
