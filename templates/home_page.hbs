<div class="hero">
  {{#if settings.show_hero}}
    <h1 class="hero__title">{{settings.hero_title}}</h1>
    <p class="hero__subtitle">Search our knowledge base or browse categories below</p>
  {{/if}}

  <div class="search-container" role="search">
    {{search submit=false}}
  </div>
</div>

<main role="main" class="home-page">
  <div class="container">
    {{#if categories}}
      <ul class="sections-accordion" id="sections-accordion">
        {{#each categories}}
          {{#each sections}}
            <li class="section-card {{#is name 'Getting Started'}}section-card--featured{{/is}}" data-section-id="{{id}}">
              <button type="button" class="section-card__header" aria-expanded="false" aria-controls="section-body-{{id}}">
                <div class="section-card__heading">
                  <h2 class="section-card__title">{{name}}</h2>
                  {{#if description}}
                    <p class="section-card__description">{{description}}</p>
                  {{/if}}
                </div>
                <svg class="section-card__chevron" width="22" height="22" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="section-card__body" id="section-body-{{id}}">
                {{#if articles}}
                  <ul class="section-articles">
                    {{#each articles}}
                      <li>
                        <a href="{{url}}" class="section-article-link">
                          <span>{{title}}</span>
                          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <path d="M5 13l5-5-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </a>
                      </li>
                    {{/each}}
                  </ul>
                {{else}}
                  <p class="text-muted" style="padding: 16px 0;">No articles in this section yet.</p>
                {{/if}}
              </div>
            </li>
          {{/each}}
        {{/each}}
      </ul>
    {{else}}
      <p class="text-muted" style="text-align:center; padding: 48px 0;">No content yet. Check back soon.</p>
    {{/if}}
  </div>
</main>
