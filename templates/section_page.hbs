<main role="main" class="section-page">
  <div class="section-shell">

    <nav class="section-breadcrumb" aria-label="Breadcrumb">{{breadcrumbs}}</nav>

    <a class="section-back" href="{{help_center.url}}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
      <span>Back to handbook</span>
    </a>

    <header class="section-hero" data-section-name="{{section.name}}">
      <p class="section-eyebrow">
        <b class="section-eyebrow-kicker"></b>
        <span class="section-eyebrow-divider"></span>
        <span class="section-eyebrow-count"></span>
      </p>
      <h1 class="section-title-display">
        <em>{{section.name}}</em><span class="stop">.</span>
      </h1>
      {{#if section.description}}
        <p class="section-sub">{{section.description}}</p>
      {{/if}}
    </header>

    {{#if section.articles}}
      <div class="section-articles">
        <ul class="section-article-list">
          {{#each section.articles}}
            <li class="section-article">
              <a class="section-article-link" href="{{url}}">
                <span class="section-article-num"></span>
                <span class="section-article-title">{{title}}</span>
                <span class="section-article-arrow" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </span>
              </a>
            </li>
          {{/each}}
        </ul>
      </div>
    {{else}}
      <p class="section-empty">No articles in this chapter yet.</p>
    {{/if}}

    <div class="section-pagination">{{pagination}}</div>

    <div class="section-stuck">
      <div>
        <h4>Still stuck?</h4>
        <p>If this chapter didn't cover it, our team is on it.</p>
      </div>
      <a class="section-stuck-email" href="mailto:help@edoceposter.com">Email support</a>
    </div>
  </div>
</main>
